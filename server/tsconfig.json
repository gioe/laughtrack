{
    "extends": "@tsconfig/node20/tsconfig.json",
    "compilerOptions": {
      "allowJs": true,
      "checkJs": true,
      "outDir": "dist",
      "lib": ["dom", "ESNext"],
      "esModuleInterop": true,
      "target": "es6", 
      "sourceMap": true, 
      "strict": true,  
      "skipLibCheck": true,  
      "forceConsistentCasingInFileNames": true,
      "allowSyntheticDefaultImports": true
    },
    "include": ["src/**/*", "src/app.ts", "src/common/functions"],
    "exclude": ["node_modules"],
    "moduleResolution": "Bundler",
    "typeRoots": [
      "@types",
      "./node_modules/@types",
    ]    
  }