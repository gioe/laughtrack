  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon",
    "serve": "node --env-file=.env dist/server.js",
    "writeclubs": "npm run build && node --env-file=.env dist/jobs/writeClubs/index.js",
    "scrape": "npm run build && node --env-file=.env dist/jobs/scrape/index.js",
    "start": "npm run serve",
    "gcp-build": "tsc -p .",
    "type-check": "tsc",
    "build": "rimraf dist && tsc --noEmit false"
