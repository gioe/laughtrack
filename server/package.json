{
  "name": "laughtrack_server",
  "type": "module",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "clean": "rimraf dist/",
    "dev": "nodemon",
    "serve": "node --env-file=.env dist/server.js",
    "write-clubs": "npm run build && node --env-file=.env dist/jobs/writeClubs/index.js",
    "scrape": "npm run build && node --env-file=.env dist/jobs/scrape/index.js",
    "generate-scores": "npm run build && node --env-file=.env dist/jobs/generateScores/index.js",
    "start": "npm run serve",
    "gcp-build": "tsc -p .",
    "type-check": "tsc",
    "build": "npm run clean && tsc --noEmit false && npm run copy-sql-files",
    "copy-sql-files": "copyfiles -u 1 src/**/*.sql dist/"
  },
  "module": "CommonJS",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@google-cloud/cloud-sql-connector": "^1.3.4",
    "@google-cloud/storage": "^7.12.1",
    "@sparticuz/chromium": "^127.0.0",
    "@tsconfig/node20": "^20.1.4",
    "@types/pg-promise": "^0.0.28",
    "bcrypt": "^5.1.1",
    "body-parser": "^1.20.2",
    "cookie-parser": "^1.4.6",
    "copyfiles": "^2.4.1",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-validator": "^7.2.0",
    "google-auth-library": "^9.14.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "moment-timezone": "^0.5.45",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.3",
    "nodemon": "^3.1.0",
    "pg-monitor": "^2.1.0",
    "pg-promise": "11.4.3",
    "playwright": "^1.46.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "winston": "^3.14.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/lodash": "^4.17.7",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.5.4"
  }
}
