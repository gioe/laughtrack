{
    "extends": "@tsconfig/node20/tsconfig.json",
    "compilerOptions": {
      "allowJs": true,
      "checkJs": true,
      "outDir": "dist",
      "lib": ["dom", "ESNext"],
      "esModuleInterop": true
    },
    "include": ["src/**/*", "src/app.ts"],
    "exclude": ["node_modules"],
    "moduleResolution": "Bundler"
  }