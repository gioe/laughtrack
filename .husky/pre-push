#!/bin/sh
# iOS pbxproj sync gate. Mirrors the path filter in
# .github/workflows/ios-pbxproj-sync.yml so drift fails locally before reaching
# main instead of post-hoc on the push-to-main run.
zero=0000000000000000000000000000000000000000
needs_pbxproj_check=0
while read local_ref local_oid remote_ref remote_oid; do
    [ -z "$local_oid" ] && continue
    [ "$local_oid" = "$zero" ] && continue
    if [ "$remote_oid" = "$zero" ]; then
        if git rev-parse --verify --quiet origin/main >/dev/null; then
            range="origin/main..$local_oid"
        else
            needs_pbxproj_check=1
            break
        fi
    else
        range="$remote_oid..$local_oid"
    fi
    if git diff --name-only "$range" 2>/dev/null | \
        grep -qE '^(ios/Sources/.*\.swift|ios/Tests/.*\.swift|ios/LaughTrack\.xcodeproj/project\.pbxproj)$'; then
        needs_pbxproj_check=1
        break
    fi
done

if [ "$needs_pbxproj_check" = "1" ]; then
    ios/bin/check-pbxproj-sync.sh || exit 1
fi

cd apps/web && { [ -e node_modules ] || ln -s "$(git rev-parse --git-common-dir)/../apps/web/node_modules" node_modules; } && npm run type-check
