{
    "name": "laughtrack-client",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "flask-dev": "FLASK_DEBUG=1 pip3 install -r requirements.txt && python3 -m flask --app api/index run -p 5328",
        "next-dev": "next dev",
        "dev": "concurrently \"npm run next-dev\" \"npm run flask-dev\"",
        "build": "next build",
        "start": "next start",
        "lint": "next lint",
        "lint:fix": "eslint --fix \"src/**/*.{js,jsx,ts,tsx}\"",
        "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\"",
        "serve": "node --env-file=.env dist/server.js",
        "hash": "node --env-file=.env dist/jobs/generateHashes/index.ts",
        "scrape": "node --env-file=.env jobs/scrape/index.ts",
        "score": "node --env-file=.env dist/jobs/generateScores/index.ts",
        "gcp-build": "tsc -p .",
        "type-check": "tsc -b"
    },
