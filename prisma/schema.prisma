generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model City {
  id    Int    @id @default(autoincrement())
  name  String @unique
  clubs Club[]

  @@map("cities")
}

model Club {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  address     String
  website     String
  scrapingUrl String       @map("scraping_url")
  popularity  Float        @default(0.0)
  zipCode     String?      @map("zip_code") @db.VarChar(10)
  cityId      Int          @map("city_id")
  phoneNumber String?      @default("") @map("phone_number")
  timezone    String?      @map("timezone")
  visible     Boolean?     @default(true)
  city        City         @relation(fields: [cityId], references: [id], onDelete: Cascade)
  scraper      String?
  shows       Show[]
  taggedClubs TaggedClub[]

  @@map("clubs")
}

model Comedian {
  id                 Int                @id @default(autoincrement())
  name               String             @unique
  instagramAccount   String?            @map("instagram_account")
  instagramFollowers Int?               @map("instagram_followers")
  tiktokAccount      String?            @map("tiktok_account")
  tiktokFollowers    Int?               @map("tiktok_followers")
  website            String?
  popularity         Float              @default(0.0)
  youtubeAccount     String?            @map("youtube_account")
  youtubeFollowers   Int?               @map("youtube_followers")
  uuid               String             @unique
  linktree           String?
  favoriteComedians  FavoriteComedian[]
  lineupItems        LineupItem[]
  taggedComedians    TaggedComedian[]
  parentComedianId   Int?              @map("parent_comedian_id")
  parentComedian     Comedian?         @relation("ComedianAliases", fields: [parentComedianId], references: [id])
  alternativeNames   Comedian[]        @relation("ComedianAliases")

  @@map("comedians")
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String          @unique
  emailVerified DateTime?
  accounts      Account[]
  sessions      Session[]
  favoriteComedians     FavoriteComedian[]
  profile       UserProfile?  // One-to-one relation

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
 
model UserProfile {
  id           String             @id @default(cuid())
  user         User               @relation(fields: [userId], references: [id])
  userId       String             @unique
  role         String             @default("user")
  emailShowNotifications Boolean  @default(false) @map("email_show_notifications")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@id([provider, providerAccountId])
}
 
model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
 
model VerificationToken {
  identifier String
  token      String
  expires    DateTime
 
  @@id([identifier, token])
}

model FavoriteComedian {
  id         Int      @default(autoincrement())
  comedianId String   @map("comedian_id")
  userId     String   @map("user_id")
  comedian   Comedian @relation(fields: [comedianId], references: [uuid], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])

  @@id([userId, comedianId])
  @@map("favorite_comedians")
}

model Show {
  id                  Int          @id @default(autoincrement())
  name                String?
  date                DateTime     @db.Timestamptz(6)
  showPageUrl         String       @map("show_page_url")
  clubId              Int          @map("club_id")
  ticketPriceCurrency String       @default("USD") @map("ticket_price_currency")
  popularity          Float        @default(0.0)
  lastScrapedDate     DateTime?    @map("last_scraped_date") @db.Timestamptz(6)
  description         String?
  ticketPurchaseUrl   String?      @map("ticket_purchase_url")
  ticketPrice         Decimal?     @map("ticket_price") @db.Decimal(5, 2)
  soldOut             Boolean      @default(false) @map("sold_out")
  lineupItems         LineupItem[]
  club                Club         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  taggedShows         TaggedShow[]

  @@unique([clubId, date])
  @@map("shows")
}

model LineupItem {
  id         Int      @default(autoincrement())
  showId     Int      @map("show_id")
  comedianId String   @map("comedian_id")
  comedian   Comedian @relation(fields: [comedianId], references: [uuid], onDelete: Cascade)
  show       Show     @relation(fields: [showId], references: [id], onDelete: Cascade)

  @@id([showId, comedianId])
  @@map("lineup_items")
}

model Tag {
  id              Int              @default(autoincrement()) @unique 
  display         String?
  type            String           // Removed ? to make it required
  userFacing      Boolean          @default(false) @map("user_facing")
  value           String           // Removed ? to make it required
  taggedClubs     TaggedClub[]
  taggedComedians TaggedComedian[]
  taggedShows     TaggedShow[]

  @@id([value, type])  // Create compound primary key
  @@map("tags")
}

model TaggedClub {
  id     Int  @default(autoincrement())
  clubId Int  @map("club_id")
  tagId  Int  @map("tag_id")
  club   Club @relation(fields: [clubId], references: [id])
  tag    Tag  @relation(fields: [tagId], references: [id])

  @@id([clubId, tagId])
  @@map("tagged_clubs")
}

model TaggedComedian {
  id         Int      @default(autoincrement())
  comedianId String   @map("comedian_id")
  tagId      Int      @map("tag_id")
  comedian   Comedian @relation(fields: [comedianId], references: [uuid], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id])

  @@id([comedianId, tagId])
  @@map("tagged_comedians")
}

model TaggedShow {
  id     Int  @default(autoincrement())
  showId Int  @map("show_id")
  tagId  Int  @map("tag_id")
  show   Show @relation(fields: [showId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([showId, tagId])
  @@map("tagged_shows")
}
