generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


model Club {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  address     String
  website     String
  scrapingUrl String       @map("scraping_url")
  popularity  Float        @default(0.0)
  zipCode     String?      @map("zip_code") @db.VarChar(10)
  phoneNumber String?      @default("") @map("phone_number")
  timezone    String?      @map("timezone")
  visible     Boolean?     @default(true)
  scraper     String?
  shows       Show[]
  taggedClubs TaggedClub[]

  @@map("clubs")
}

model Comedian {
  id                 Int                @id @default(autoincrement())
  name               String             @unique
  instagramAccount   String?            @map("instagram_account")
  instagramFollowers Int?               @map("instagram_followers")
  tiktokAccount      String?            @map("tiktok_account")
  tiktokFollowers    Int?               @map("tiktok_followers")
  website            String?
  popularity         Float              @default(0.0)
  youtubeAccount     String?            @map("youtube_account")
  youtubeFollowers   Int?               @map("youtube_followers")
  uuid               String             @unique
  totalShows         Int                @default(0) @map("total_shows")
  soldOutShows       Int                @default(0) @map("sold_out_shows")
  linktree           String?
  favoriteComedians  FavoriteComedian[]
  lineupItems        LineupItem[]
  taggedComedians    TaggedComedian[]
  parentComedianId   Int?              @map("parent_comedian_id")
  parentComedian     Comedian?         @relation("ComedianAliases", fields: [parentComedianId], references: [id])
  alternativeNames   Comedian[]        @relation("ComedianAliases")

  @@map("comedians")
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String          @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  profile       UserProfile?  // One-to-one relation

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("users")
}
 
model UserProfile {
  id                     String             @id @default(cuid())
  user                   User               @relation(fields: [userId], references: [id])
  userId                 String             @unique
  role                   String             @default("user")
  emailShowNotifications Boolean  @default(false) @map("email_show_notifications")
  favoriteComedians      FavoriteComedian[]
  zipCode                String?            @map("zip_code")
  @@map("user_profiles")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@id([provider, providerAccountId])
  @@map("accounts")
}
 
model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("sessions")
}
 
model VerificationToken {
  identifier String
  token      String
  expires    DateTime
 
  @@id([identifier, token])
  @@map("tokens")
}

model FavoriteComedian {
  id         Int             @default(autoincrement())
  comedianId String          @map("comedian_id")
  profileId     String       @map("profile_id")
  comedian   Comedian        @relation(fields: [comedianId], references: [uuid], onDelete: Cascade)
  user       UserProfile     @relation(fields: [profileId], references: [id])

  @@id([profileId, comedianId])
  @@map("favorite_comedians")
}

model Show {
  id                  Int          @id @default(autoincrement())
  name                String?
  date                DateTime     @db.Timestamptz(6)
  showPageUrl         String       @map("show_page_url")
  clubId              Int          @map("club_id")
  popularity          Float        @default(0.0)
  lastScrapedDate     DateTime?    @map("last_scraped_date") @db.Timestamptz(6)
  description         String?
  tickets             Ticket[]     // New relation to Ticket model
  lineupItems         LineupItem[]
  club                Club         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  taggedShows         TaggedShow[]

  @@unique([clubId, date])
  @@map("shows")
}

model Ticket {
  id                Int      @id @default(autoincrement())
  purchaseUrl       String?  @map("purchase_url")
  price             Decimal? @map("price") @db.Decimal(5, 2)
  soldOut           Boolean  @default(false) @map("sold_out")
  showId            Int      @map("show_id")
  show              Show     @relation(fields: [showId], references: [id], onDelete: Cascade)
  ticketType        String?  @map("ticket_type")  // Optional ticket type field

  @@map("tickets")
}

model LineupItem {
  id         Int      @default(autoincrement())
  showId     Int      @map("show_id")
  comedianId String   @map("comedian_id")
  comedian   Comedian @relation(fields: [comedianId], references: [uuid], onDelete: Cascade)
  show       Show     @relation(fields: [showId], references: [id], onDelete: Cascade)

  @@id([showId, comedianId])
  @@map("lineup_items")
}

model Tag {
  id              Int              @id @default(autoincrement())
  display         String?
  type            String           
  userFacing      Boolean          @default(false) @map("user_facing")
  value           String           
  taggedClubs     TaggedClub[]
  taggedComedians TaggedComedian[]
  taggedShows     TaggedShow[]

  @@unique([type, value])  // Instead of making it the primary key
  @@map("tags")
}

model TaggedClub {
  id     Int  @id @default(autoincrement())
  clubId Int  @map("club_id")
  tagId  Int  @map("tag_id")
  club   Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id])

  @@map("tagged_clubs")
}

model TaggedComedian {
  id         Int      @id @default(autoincrement())
  comedianId String   @map("comedian_id")
  tagId      Int      @map("tag_id")
  comedian   Comedian @relation(fields: [comedianId], references: [uuid], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id])

  @@map("tagged_comedians")
}

model TaggedShow {
  id         Int  @id @default(autoincrement())
  showId     Int  @map("show_id")
  tagId      Int  @map("tag_id")
  show       Show @relation(fields: [showId], references: [id], onDelete: Cascade)
  tag        Tag  @relation(fields: [tagId], references: [id])
  
  @@map("tagged_shows")
}
