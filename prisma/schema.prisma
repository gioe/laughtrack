// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DIRECT_URL")
}

model City {
  id    Int    @id @default(autoincrement())
  name  String @unique
  clubs Club[]

  @@map("cities")
}

model Club {
  id           Int          @id @default(autoincrement())
  name         String       @unique
  address      String
  website      String
  scraping_url String
  popularity   Float        @default(0.0)
  zip_code     String?      @db.VarChar(10)
  city_id      Int
  scraper_type String?
  city         City         @relation(fields: [city_id], references: [id], onDelete: Cascade)
  shows        Show[]
  taggedClubs  TaggedClub[]

  @@map("clubs")
}


model Comedian {
  id                  Int                @id @default(autoincrement())
  name               String             @unique
  instagram_account  String?
  instagram_followers Int?
  tiktok_account     String?
  tiktok_followers   Int?
  website            String?
  popularity         Float              @default(0.0)
  youtube_account    String?
  youtube_followers  Int?
  uuid               String             @unique
  linktree           String?
  favoriteComedians  FavoriteComedian[]
  lineupItems        LineupItem[]
  taggedComedians    TaggedComedian[]

  @@map("comedians")
}

model User {
  id                Int                 @id @default(autoincrement())
  email             String              @unique
  password          String
  role              String              @default("user")
  zip_code          String?             @db.VarChar(10)
  favoriteComedians FavoriteComedian[]

  @@map("users")
}

model FavoriteComedian {
  id          Int      @default(autoincrement())
  comedian_id String
  user_id     Int
  comedian    Comedian @relation(fields: [comedian_id], references: [uuid], onDelete: Cascade)
  user        User     @relation(fields: [user_id], references: [id])

  @@id([user_id, comedian_id])
  @@map("favorite_comedians")
}

model Show {
  id                  Int            @id @default(autoincrement())
  name               String?
  date               DateTime
  show_page_url      String
  club_id            Int
  ticket_price_currency String      @default("USD")
  popularity         Float          @default(0.0)
  last_scraped_date  DateTime?
  description        String?
  ticket_purchase_url String?
  ticket_price       Decimal?       @db.Decimal(5,2)
  supplied_tags      String[]
  club               Club           @relation(fields: [club_id], references: [id], onDelete: Cascade)
  lineupItems        LineupItem[]
  taggedShows        TaggedShow[]

  @@unique([club_id, date])
  @@map("shows")
}

model LineupItem {
  id          Int      @default(autoincrement())
  show_id     Int
  comedian_id String
  show        Show     @relation(fields: [show_id], references: [id], onDelete: Cascade)
  comedian    Comedian @relation(fields: [comedian_id], references: [uuid], onDelete: Cascade)

  @@id([show_id, comedian_id])
  @@map("lineup_items")
}

model TagCategory {
  id      Int      @id @default(autoincrement())
  display String?
  type    String?
  value   String?
  tags    Tag[]

  @@map("tag_category")
}

model Tag {
  id            Int             @id @default(autoincrement())
  display       String?
  type         String?
  user_facing  Boolean         @default(false)
  pattern      String?
  category     Int?
  value        String?
  key_words    String[]
  tagCategory  TagCategory?    @relation(fields: [category], references: [id], onDelete: Cascade)
  taggedClubs  TaggedClub[]
  taggedComedians TaggedComedian[]
  taggedShows  TaggedShow[]

  @@map("tags")
}

model TaggedClub {
  id       Int   @default(autoincrement())
  club_id  Int
  tag_id   Int
  club     Club  @relation(fields: [club_id], references: [id])
  tag      Tag   @relation(fields: [tag_id], references: [id])

  @@id([club_id, tag_id])
  @@map("tagged_clubs")
}

model TaggedComedian {
  id          Int      @default(autoincrement())
  comedian_id String
  tag_id      Int
  comedian    Comedian @relation(fields: [comedian_id], references: [uuid], onDelete: Cascade)
  tag         Tag      @relation(fields: [tag_id], references: [id])

  @@id([comedian_id, tag_id])
  @@map("tagged_comedians")
}

model TaggedShow {
  id       Int   @default(autoincrement())
  show_id  Int
  tag_id   Int
  show     Show  @relation(fields: [show_id], references: [id], onDelete: Cascade)
  tag      Tag   @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([show_id, tag_id])
  @@map("tagged_shows")
}
