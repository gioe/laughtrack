# =============================================================================
# LaughTrack Web App — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
#
#   cp apps/web/.env.example apps/web/.env.local
#
# Never commit .env.local — it is listed in .gitignore.
# =============================================================================


# --- Database (Prisma / Neon PostgreSQL) -------------------------------------

# Pooled connection URL used by Prisma at runtime.
DATABASE_URL="postgresql://user:password@host/dbname?pgbouncer=true"

# Direct (non-pooled) connection URL used by Prisma for migrations.
DIRECT_URL="postgresql://user:password@host/dbname"


# --- Authentication (NextAuth v5) --------------------------------------------

# A random secret used to sign session tokens. Generate one with:
#   openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret"

# Google OAuth credentials — create an app at https://console.cloud.google.com
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# Apple Sign In credentials — create an app at https://developer.apple.com
AUTH_APPLE_ID="your-apple-client-id"
AUTH_APPLE_SECRET="your-apple-client-secret"


# --- CDN (Bunny CDN) ---------------------------------------------------------

# Hostname for your Bunny CDN pull zone (e.g. laughtrack.b-cdn.net).
BUNNYCDN_CDN_HOST="your-zone.b-cdn.net"


# --- Security ----------------------------------------------------------------

# Secret key used to sign JWT tokens (e.g. unsubscribe links).
# Generate one with: openssl rand -base64 32
SECRET_KEY="your-secret-key"


# --- Public App Config -------------------------------------------------------

# Canonical URL of the site — used for absolute URLs and OG meta tags.
# Use http://localhost:3000 for local development.
NEXT_PUBLIC_WEBSITE_URL="http://localhost:3000"


# --- CORS --------------------------------------------------------------------

# Comma-separated list of allowed origins for API responses.
# Defaults to NEXT_PUBLIC_WEBSITE_URL if not set.
CORS_ALLOWED_ORIGINS="http://localhost:3000"


# --- Storage (optional) ------------------------------------------------------

# Absolute path to a local directory used for file storage (non-production).
# Not required in Cloud Run deployments.
DIRECTORY_PATH="/tmp/laughtrack"


# --- Deployment (auto-set) ---------------------------------------------------

# Set automatically by Google Cloud Run to the current revision name.
# Used to detect whether the app is running in a cloud environment.
# Do NOT set this in local development.
# K_REVISION=
