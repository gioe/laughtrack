# =============================================================================
# LaughTrack Web App — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Run this from the repo root:
#
#   cp apps/web/.env.example apps/web/.env.local
#
# Never commit .env.local — it is listed in .gitignore.
# =============================================================================

# --- Database (Prisma / PostgreSQL) ------------------------------------------
#
# Local development (postgresql@15 via Homebrew):
#   DATABASE_URL="postgresql://localhost/laughtrack"
#   DIRECT_URL="postgresql://localhost/laughtrack"
#
# Production (Neon or Supabase hosted PostgreSQL):
#   DATABASE_URL="postgresql://user:password@host/dbname?pgbouncer=true"
#   DIRECT_URL="postgresql://user:password@host/dbname"

# Pooled connection URL used by Prisma at runtime.
DATABASE_URL="postgresql://localhost/laughtrack"

# Direct (non-pooled) connection URL used by Prisma for migrations.
DIRECT_URL="postgresql://localhost/laughtrack"


# --- Authentication (NextAuth v5) --------------------------------------------

# A random secret used to sign session tokens. Generate one with:
#   openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret"

# Google OAuth credentials — create an app at https://console.cloud.google.com
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# Apple Sign In credentials — create an app at https://developer.apple.com
# AUTH_APPLE_SECRET must be the contents of the .p8 private key file downloaded
# from Apple Developer, with newlines replaced by literal \n characters, e.g.:
#   -----BEGIN PRIVATE KEY-----\nMIGT...\n-----END PRIVATE KEY-----
# See https://next-auth.js.org/providers/apple for full setup instructions.
AUTH_APPLE_ID="your-apple-client-id"
AUTH_APPLE_SECRET="-----BEGIN PRIVATE KEY-----\nMIGT...\n-----END PRIVATE KEY-----"

# Canonical URL used by NextAuth v5 to build OAuth callback URLs.
# Required when the host cannot be inferred from the request (e.g. Cloud Run).
# Use http://localhost:3000 for local development.
AUTH_URL="http://localhost:3000"


# --- Email (magic-link sign-in via Nodemailer) --------------------------------
#
# Required for email magic-link authentication.
# Without these vars the provider startup guard throws at boot in production;
# in development, sign-in emails send silently but are never delivered.
#
# Obtain SMTP credentials from your mail provider (e.g. Gmail, SendGrid, Postmark).
# To use Gmail: https://support.google.com/mail/answer/185833 (App Passwords)

# SMTP server hostname (e.g. smtp.gmail.com, smtp.sendgrid.net)
SMTP_HOST="smtp.example.com"

# SMTP port — 587 for STARTTLS (recommended), 465 for SSL, 25 for plaintext
SMTP_PORT="587"

# SMTP account username (usually an email address)
SMTP_USER="your-smtp-username@example.com"

# SMTP account password or app-specific password
SMTP_PASSWORD="your-smtp-password"

# SMTP TLS mode — set to "true" when using port 465 (SSL), "false" for port 587 (STARTTLS)
# Port 465 requires secure: true; port 587 negotiates TLS via STARTTLS (secure: false).
SMTP_SECURE="false"

# The "From" address shown in magic-link emails sent to users
EMAIL_FROM="noreply@laughtrack.com"


# --- CDN (Bunny CDN) ---------------------------------------------------------

# Hostname for your Bunny CDN pull zone (e.g. laughtrack.b-cdn.net).
BUNNYCDN_CDN_HOST="your-zone.b-cdn.net"


# --- Security ----------------------------------------------------------------

# Secret key used to sign JWT tokens (e.g. unsubscribe links).
# Generate one with: openssl rand -base64 32
SECRET_KEY="your-secret-key"


# --- Public App Config -------------------------------------------------------

# Canonical URL of the site — used for absolute URLs and OG meta tags.
# Use http://localhost:3000 for local development.
NEXT_PUBLIC_WEBSITE_URL="http://localhost:3000"


# --- CORS --------------------------------------------------------------------

# Comma-separated list of allowed origins for API responses.
# Defaults to NEXT_PUBLIC_WEBSITE_URL if not set.
CORS_ALLOWED_ORIGINS="http://localhost:3000"


# --- Storage (optional) ------------------------------------------------------

# Absolute path to a local directory used for file storage (non-production).
# Not required in Cloud Run deployments.
DIRECTORY_PATH="/tmp/laughtrack"


# --- Deployment (auto-set) ---------------------------------------------------

# Set automatically by Google Cloud Run to the current revision name.
# Used to detect whether the app is running in a cloud environment.
# Do NOT set this in local development.
# K_REVISION=
