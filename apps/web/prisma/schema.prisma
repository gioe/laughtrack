generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  binaryTargets   = ["native", "rhel-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Club {
  id                 Int                 @id @default(autoincrement())
  name               String              @unique
  address            String
  website            String
  scrapingUrl        String              @map("scraping_url")
  popularity         Float               @default(0.0)
  zipCode            String?             @map("zip_code") @db.VarChar(10)
  city               String?             @map("city")
  state              String?             @map("state")
  phoneNumber        String?             @default("") @map("phone_number")
  timezone           String?             @map("timezone")
  visible            Boolean?            @default(true)
  scraper            String?
  seatengineId       String?             @map("seatengine_id")
  eventbriteId       String?             @map("eventbrite_id")
  ticketmasterId     String?             @map("ticketmaster_id")
  totalShows         Int                 @default(0) @map("total_shows")
  hasImage           Boolean             @default(false) @map("has_image")
  status             String              @default("active")
  closedAt           DateTime?           @map("closed_at")
  shows              Show[]
  taggedClubs        TaggedClub[]
  emailSubscriptions EmailSubscription[]
  processedEmails    ProcessedEmail[]

  @@index([visible])
  @@map("clubs")
}

model Comedian {
  id                 Int                @id @default(autoincrement())
  name               String
  instagramAccount   String?            @map("instagram_account")
  instagramFollowers Int?               @map("instagram_followers")
  tiktokAccount      String?            @map("tiktok_account")
  tiktokFollowers    Int?               @map("tiktok_followers")
  website            String?
  popularity         Float              @default(0.0)
  youtubeAccount     String?            @map("youtube_account")
  youtubeFollowers   Int?               @map("youtube_followers")
  uuid               String             @unique
  totalShows         Int                @default(0) @map("total_shows")
  soldOutShows       Int                @default(0) @map("sold_out_shows")
  linktree           String?
  songkickId         String?            @map("songkick_id")
  bandsintownId      String?            @map("bandsintown_id")
  hasImage           Boolean            @default(false) @map("has_image")
  websiteDiscoverySource String?        @map("website_discovery_source")
  websiteLastScraped     DateTime?      @map("website_last_scraped") @db.Timestamptz
  websiteScrapeStrategy  String?        @map("website_scrape_strategy")
  websiteScrapingUrl     String?        @map("website_scraping_url")
  websiteConfidence      String?        @map("website_confidence")
  websiteScrapingUrlConfidence String?  @map("website_scraping_url_confidence")
  parentComedianId   Int?               @map("parent_comedian_id")
  parentComedian     Comedian?          @relation("ComedianAliases", fields: [parentComedianId], references: [id])
  alternativeNames   Comedian[]         @relation("ComedianAliases")
  favoriteComedians  FavoriteComedian[]
  lineupItems        LineupItem[]
  taggedComedians    TaggedComedian[]
  sentNotifications  SentNotification[]

  @@index([parentComedianId])
  @@map("comedians")
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String       @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  accounts          Account[]
  profile           UserProfile?
  sentNotifications SentNotification[]

  @@map("users")
}

model UserProfile {
  id                     String             @id @default(cuid())
  role                   String             @default("user")
  emailShowNotifications Boolean            @default(false) @map("email_show_notifications")
  zipCode                String?            @map("zip_code")
  userid                 String             @unique @map("user_id")
  favoriteComedians      FavoriteComedian[]
  user                   User               @relation(fields: [userid], references: [id])

  @@map("user_profiles")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("tokens")
}

model FavoriteComedian {
  id         Int         @default(autoincrement())
  comedianId String      @map("comedian_id")
  profileId  String      @map("profile_id")
  comedian   Comedian    @relation(fields: [comedianId], references: [uuid], onDelete: Cascade)
  user       UserProfile @relation(fields: [profileId], references: [id])

  @@id([profileId, comedianId])
  @@map("favorite_comedians")
}

model Show {
  id              Int          @id @default(autoincrement())
  name            String?
  date            DateTime     @db.Timestamptz(6)
  showPageUrl     String       @map("show_page_url")
  clubId          Int          @map("club_id")
  popularity      Float        @default(0.0)
  lastScrapedDate DateTime?    @map("last_scraped_date") @db.Timestamptz(6)
  description     String?
  room            String?
  lineupItems        LineupItem[]
  club               Club               @relation(fields: [clubId], references: [id], onDelete: Cascade)
  taggedShows        TaggedShow[]
  tickets            Ticket[]
  sentNotifications  SentNotification[]

  // Dual-index design (intentional):
  // - @@unique([clubId, date, room]) enforces deduplication and is used by the
  //   query planner when filtering on both clubId and date (e.g. upsert lookups
  //   and show-page queries scoped to a single club).
  // - @@index([date]) is a standalone index used for range-only date queries
  //   (e.g. "shows between date A and date B" across all clubs). PostgreSQL will
  //   prefer the narrower composite index when clubId is in the predicate and the
  //   standalone index when only date is filtered.
  @@unique([clubId, date, room])
  @@index([date])
  @@map("shows")
}

model Ticket {
  id          Int      @id @default(autoincrement())
  purchaseUrl String?  @map("purchase_url")
  price       Decimal? @map("price") @db.Decimal(5, 2)
  soldOut     Boolean  @default(false) @map("sold_out")
  showId      Int      @map("show_id")
  type        String?  @map("type")
  show        Show     @relation(fields: [showId], references: [id], onDelete: Cascade)

  @@unique([showId, type])
  @@map("tickets")
}

model LineupItem {
  id         Int      @default(autoincrement())
  showId     Int      @map("show_id")
  comedianId String   @map("comedian_id")
  comedian   Comedian @relation(fields: [comedianId], references: [uuid], onDelete: Cascade)
  show       Show     @relation(fields: [showId], references: [id], onDelete: Cascade)

  @@id([showId, comedianId])
  @@map("lineup_items")
}

model Tag {
  id              Int              @id @default(autoincrement())
  type            String
  userFacing      Boolean          @default(false) @map("user_facing")
  name            String?
  restrictContent Boolean          @default(false)
  slug            String?
  visibility      TagVisibility    @default(ADMIN)
  taggedClubs     TaggedClub[]
  taggedComedians TaggedComedian[]
  taggedShows     TaggedShow[]

  @@unique([type, slug])
  @@index([visibility])
  @@index([restrictContent])
  @@map("tags")
}

model TaggedClub {
  id     Int  @id @default(autoincrement())
  clubId Int  @map("club_id")
  tagId  Int  @map("tag_id")
  club   Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id])

  @@map("tagged_clubs")
}

model TaggedComedian {
  id         Int      @id @default(autoincrement())
  comedianId String   @map("comedian_id")
  tagId      Int      @map("tag_id")
  comedian   Comedian @relation(fields: [comedianId], references: [uuid], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id])

  @@unique([comedianId, tagId])
  @@map("tagged_comedians")
}

model TaggedShow {
  id     Int  @id @default(autoincrement())
  showId Int  @map("show_id")
  tagId  Int  @map("tag_id")
  show   Show @relation(fields: [showId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id])

  @@unique([showId, tagId])
  @@map("tagged_shows")
}

enum TagVisibility {
  PUBLIC
  ADMIN
}

model EmailSubscription {
  id           Int       @id @default(autoincrement())
  clubId       Int       @unique @map("club_id")
  senderDomain String    @map("sender_domain")
  subscribed   Boolean   @default(true)
  lastReceived DateTime? @map("last_received")
  createdAt    DateTime  @default(now()) @map("created_at")
  club         Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@map("email_subscriptions")
}

model ProcessedEmail {
  id          Int      @id @default(autoincrement())
  messageId   String   @unique @map("message_id")
  clubId      Int      @map("club_id")
  receivedAt  DateTime @map("received_at")
  processedAt DateTime @default(now()) @map("processed_at")
  club        Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@map("processed_emails")
}

model SentNotification {
  id               Int      @id @default(autoincrement())
  userId           String   @map("user_id")
  comedianId       String   @map("comedian_id")
  showId           Int      @map("show_id")
  notificationType String   @default("email") @map("notification_type")
  sentAt           DateTime @default(now()) @map("sent_at")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  comedian         Comedian @relation(fields: [comedianId], references: [uuid], onDelete: Cascade)
  show             Show     @relation(fields: [showId], references: [id], onDelete: Cascade)

  @@unique([userId, comedianId, showId, notificationType], name: "sent_notifications_unique_per_channel")
  @@index([userId])
  @@map("sent_notifications")
}
