#!/usr/bin/env python3
"""
Detect and optionally remove orphaned venue scraper directories.

A venue scraper directory is "orphaned" (stale) when its scraper key is no longer
referenced by any club row in the database — typically because the venue was migrated
to a generic API scraper (e.g. haha_comedy_club → tixr).

Usage:
    cd apps/scraper && python bin/cleanup-stale-scrapers           # report only
    cd apps/scraper && python bin/cleanup-stale-scrapers --apply   # delete orphans

Only scrapers under scrapers/implementations/venues/ are checked.  National/discovery
scrapers under api/ are excluded.  For each venue directory the script reads the
scraper.py file and extracts the class-level `key = "..."` attribute.

Corresponding test directories (tests/scrapers/implementations/venues/<name>/) are
deleted alongside the implementation directory when --apply is passed.
"""
import argparse
import ast
import os
import re
import shutil
import sys
from pathlib import Path

# ---------------------------------------------------------------------------
# Locate project root and load .env
# ---------------------------------------------------------------------------
SCRIPT_DIR = Path(__file__).resolve().parent
SCRAPER_ROOT = SCRIPT_DIR.parent  # apps/scraper/
ENV_FILE = SCRAPER_ROOT / ".env"

VENUES_DIR = SCRAPER_ROOT / "src" / "laughtrack" / "scrapers" / "implementations" / "venues"
TESTS_VENUES_DIR = SCRAPER_ROOT / "tests" / "scrapers" / "implementations" / "venues"

try:
    from dotenv import load_dotenv
except ImportError:
    print("Error: python-dotenv is not installed. Run: pip install python-dotenv", file=sys.stderr)
    sys.exit(1)

if not ENV_FILE.exists():
    print(f"Warning: .env not found at {ENV_FILE} — falling back to environment variables")

load_dotenv(ENV_FILE)

DATABASE_URL = os.environ.get("DATABASE_URL")
if not DATABASE_URL:
    print(f"Error: DATABASE_URL not set. Add it to {ENV_FILE}", file=sys.stderr)
    sys.exit(1)

try:
    import psycopg2
except ImportError:
    print("Error: psycopg2 is not installed. Run: pip install psycopg2-binary", file=sys.stderr)
    sys.exit(1)

sys.path.insert(0, str(SCRAPER_ROOT / "src"))
from laughtrack.foundation.db_util import connect_with_retry  # noqa: E402


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def get_db_scraper_keys(conn) -> set[str]:
    """Return the set of scraper keys referenced by at least one club row."""
    with conn.cursor() as cur:
        cur.execute("SELECT DISTINCT scraper FROM clubs WHERE scraper IS NOT NULL")
        return {row[0] for row in cur.fetchall()}


def extract_scraper_key(scraper_py: Path) -> str | None:
    """
    Extract the class-level `key = "..."` attribute from a scraper.py file.

    Uses regex rather than AST import to avoid executing side-effect imports.
    Returns None if no key is found.
    """
    source = scraper_py.read_text(encoding="utf-8")
    # Match:  key = "some_value"  (with optional whitespace, at class body indent)
    match = re.search(r'^\s+key\s*=\s*["\']([^"\']+)["\']', source, re.MULTILINE)
    if match:
        return match.group(1)
    return None


def scan_venue_scrapers() -> dict[str, str]:
    """
    Walk VENUES_DIR and return {scraper_key: directory_name} for every venue
    directory that contains a scraper.py with a key attribute.
    """
    result: dict[str, str] = {}
    for entry in sorted(VENUES_DIR.iterdir()):
        if not entry.is_dir():
            continue
        scraper_py = entry / "scraper.py"
        if not scraper_py.exists():
            continue
        key = extract_scraper_key(scraper_py)
        if key is None:
            print(f"  Warning: no key found in {entry.name}/scraper.py — skipping", file=sys.stderr)
            continue
        if key in result:
            print(
                f"  Warning: duplicate key '{key}' in {entry.name}/ (already seen in {result[key]}/) — skipping {entry.name}",
                file=sys.stderr,
            )
            continue
        result[key] = entry.name
    return result


def delete_directory(path: Path) -> None:
    if path.exists():
        shutil.rmtree(path)
        print(f"  Deleted {path.relative_to(SCRAPER_ROOT)}")
    else:
        print(f"  (not found, skipped) {path.relative_to(SCRAPER_ROOT)}")


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main() -> None:
    parser = argparse.ArgumentParser(
        description="Detect orphaned venue scraper directories whose keys are absent from the DB"
    )
    parser.add_argument(
        "--apply",
        action="store_true",
        help="Delete orphaned implementation and test directories (default: report only)",
    )
    args = parser.parse_args()

    if not VENUES_DIR.is_dir():
        print(f"Error: venues directory not found at {VENUES_DIR}", file=sys.stderr)
        sys.exit(1)

    # Step 1 — query DB
    conn = connect_with_retry(DATABASE_URL)
    try:
        db_keys = get_db_scraper_keys(conn)
    finally:
        conn.close()

    print(f"DB scraper keys ({len(db_keys)}): {', '.join(sorted(db_keys))}\n")

    # Step 2 — scan venue scraper directories
    code_scrapers = scan_venue_scrapers()  # {key: dir_name}
    print(f"Venue scrapers in code ({len(code_scrapers)}): {', '.join(sorted(code_scrapers))}\n")

    # Step 3 — find orphans
    orphaned = {key: dirname for key, dirname in code_scrapers.items() if key not in db_keys}

    if not orphaned:
        print("No orphaned scrapers found — everything in code is referenced by the DB.")
        return

    print(f"Orphaned scrapers ({len(orphaned)}):")
    for key, dirname in sorted(orphaned.items()):
        impl_path = VENUES_DIR / dirname
        test_path = TESTS_VENUES_DIR / dirname
        test_exists = "  (test dir exists)" if test_path.exists() else "  (no test dir)"
        print(f"  key='{key}'  dir={dirname}/{test_exists}")

    if not args.apply:
        print(
            "\nRun with --apply to delete the orphaned directories above "
            "(implementation + tests)."
        )
        return

    print("\nDeleting orphaned directories...")
    for key, dirname in sorted(orphaned.items()):
        impl_path = VENUES_DIR / dirname
        test_path = TESTS_VENUES_DIR / dirname
        print(f"\n  [{key}]")
        delete_directory(impl_path)
        delete_directory(test_path)

    print(f"\nDone — removed {len(orphaned)} orphaned scraper(s).")


if __name__ == "__main__":
    main()
