#!/usr/bin/env python3
"""
Apply pending SQL migrations from apps/scraper/migrations/.

Usage:
    cd apps/scraper && python bin/migrate          # apply pending migrations
    cd apps/scraper && python bin/migrate --dry-run  # show what would run

Reads DATABASE_URL from apps/scraper/.env. Tracks applied migrations in a
migrations_log table (auto-created on first run) so re-running is idempotent.
Uses an advisory lock to serialize concurrent invocations.
"""
import argparse
import os
import sys
from pathlib import Path

# ---------------------------------------------------------------------------
# Locate project root and load .env
# ---------------------------------------------------------------------------
SCRIPT_DIR = Path(__file__).resolve().parent
SCRAPER_ROOT = SCRIPT_DIR.parent  # apps/scraper/
ENV_FILE = SCRAPER_ROOT / ".env"
MIGRATIONS_DIR = SCRAPER_ROOT / "migrations"

try:
    from dotenv import load_dotenv
except ImportError:
    print("Error: python-dotenv is not installed. Run: pip install python-dotenv", file=sys.stderr)
    sys.exit(1)

if not ENV_FILE.exists():
    print(f"Warning: .env not found at {ENV_FILE} — falling back to environment variables")

load_dotenv(ENV_FILE)

DATABASE_URL = os.environ.get("DATABASE_URL")
if not DATABASE_URL:
    print(f"Error: DATABASE_URL not set. Add it to {ENV_FILE}", file=sys.stderr)
    sys.exit(1)

try:
    import psycopg2
except ImportError:
    print("Error: psycopg2 is not installed. Run: pip install psycopg2-binary", file=sys.stderr)
    sys.exit(1)

# Add scraper src to path so standalone scripts can import from laughtrack.foundation
sys.path.insert(0, str(SCRAPER_ROOT / "src"))
from laughtrack.foundation.db_util import connect_with_retry  # noqa: E402

# ---------------------------------------------------------------------------
# DDL for the migrations log table
# ---------------------------------------------------------------------------
CREATE_LOG_TABLE = """
CREATE TABLE IF NOT EXISTS migrations_log (
    id           SERIAL PRIMARY KEY,
    filename     TEXT        NOT NULL UNIQUE,
    applied_at   TIMESTAMPTZ NOT NULL DEFAULT now()
);
"""

# Arbitrary stable key for the advisory lock (must be a bigint)
_ADVISORY_LOCK_KEY = 658_000_000


def get_applied(cur) -> set[str]:
    cur.execute("SELECT filename FROM migrations_log ORDER BY filename")
    return {row[0] for row in cur.fetchall()}


def get_pending(applied: set[str]) -> list[Path]:
    files = sorted(MIGRATIONS_DIR.glob("*.sql"))
    return [f for f in files if f.name not in applied]


def apply_migration(cur, path: Path) -> bool:
    """Apply a single migration. Returns True if applied, False if skipped (empty file)."""
    sql = path.read_text(encoding="utf-8").strip()
    if not sql:
        print(f"Warning: {path.name} is empty — skipping", file=sys.stderr)
        return False
    cur.execute(sql)
    cur.execute(
        "INSERT INTO migrations_log (filename) VALUES (%s) ON CONFLICT DO NOTHING",
        (path.name,),
    )
    return True


def main() -> None:
    parser = argparse.ArgumentParser(description="Apply pending SQL migrations")
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Show pending migrations without applying them",
    )
    args = parser.parse_args()

    if not MIGRATIONS_DIR.is_dir():
        print(f"Error: migrations directory not found at {MIGRATIONS_DIR}", file=sys.stderr)
        sys.exit(1)

    conn = connect_with_retry(DATABASE_URL)
    try:
        conn.autocommit = False
        with conn.cursor() as cur:
            # Serialize concurrent invocations — blocks until the lock is acquired
            cur.execute("SELECT pg_advisory_lock(%s)", (_ADVISORY_LOCK_KEY,))

            # Ensure the log table exists (idempotent)
            cur.execute(CREATE_LOG_TABLE)
            conn.commit()

            applied = get_applied(cur)
            pending = get_pending(applied)

        if not pending:
            print("No pending migrations — database is up to date.")
            return

        if args.dry_run:
            print(f"Dry run — {len(pending)} migration(s) would be applied:")
            for p in pending:
                print(f"  {p.name}")
            return

        applied_names = []
        for path in pending:
            print(f"  Applying {path.name}...", end=" ", flush=True)
            try:
                with conn.cursor() as cur:
                    applied = apply_migration(cur, path)
                if not applied:
                    continue
                conn.commit()
                applied_names.append(path.name)
                print("ok")
            except Exception as exc:
                conn.rollback()
                print(f"FAILED\nError in {path.name}: {exc}", file=sys.stderr)
                sys.exit(1)

        print(f"\nApplied {len(applied_names)} migration(s):")
        for name in applied_names:
            print(f"  ✓ {name}")

    finally:
        conn.close()


if __name__ == "__main__":
    main()
