# Example .env file for email configuration
# Copy this to .env and replace with your actual values

# SMTP Configuration (required for sending emails)
# For Gmail: smtp.gmail.com, port 587, use app password not regular password
# For Outlook: smtp-mail.outlook.com, port 587
# For Yahoo: smtp.mail.yahoo.com, port 587
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=admin@laugh-track.com
EMAIL_SMTP_PASSWORD=pugb piud dqex lmtx
EMAIL_SMTP_USE_TLS=true

# Email From Address (optional - has hardcoded fallback)
EMAIL_FROM_EMAIL=admin@laugh-track.com
EMAIL_FROM_NAME=Laughtrack Scraper

# Alert recipients for scraping reports (read by ConfigManager as ALERT_RECIPIENTS)
# REPLACE admin@laugh-track.com WITH YOUR ACTUAL EMAIL
ALERT_RECIPIENTS=admin@laugh-track.com

# For multiple recipients, separate with commas:
# ALERT_RECIPIENTS=admin@laugh-track.com,dev@yourcompany.com,team@yourcompany.com

# Note: If no SMTP credentials are provided, the system will use a mock email provider
# that logs email details instead of actually sending them.

# Scraping Concurrency
# Maximum number of clubs scraped simultaneously (default: 5)
# MAX_CONCURRENT_CLUBS=5

# SeatEngine API (optional - only needed if scraping SeatEngine-powered clubs)
# Run: bash apps/scraper/scripts/fetch_seatengine_token.sh  (or /fetch-seatengine-token)
# SEATENGINE_AUTH_TOKEN=

# Discord webhook for scraping success-rate alerts (optional)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Heartbeat monitoring — run-history observability (optional)
# Create a free check at https://healthchecks.io (period=1d, grace=12h),
# add the ping URL as a GitHub secret named HEALTHCHECKS_PING_URL.
# Alerts fire via email or Discord if no ping arrives within the grace window,
# catching both scraper failures and completely missed scheduled runs.
# HEALTHCHECKS_PING_URL=https://hc-ping.com/your-check-uuid

# Bunny CDN Storage (optional - only needed for automated image uploads)
# BUNNYCDN_STORAGE_PASSWORD=your-storage-zone-password
# BUNNYCDN_STORAGE_ZONE=your-storage-zone-name
# BUNNYCDN_STORAGE_REGION=la
