[flake8]
# =============================================================================
# FLAKE8 CONFIGURATION FOR LAUGHTRACK SCRAPER
# =============================================================================

# Maximum line length (matching black configuration)
max-line-length = 120

# Error codes to ignore
# E203: whitespace before ':' (conflicts with black)
# W503: line break before binary operator (conflicts with black)
# E501: line too long (handled by black)
extend-ignore = E203, W503, E501

# Maximum complexity for functions
max-complexity = 10

# Directories to exclude from linting
exclude = 
    .git,
    __pycache__,
    .venv,
    .mypy_cache,
    .pytest_cache,
    build,
    dist,
    *.egg-info,
    .eggs,
    logs/

# Files to include in linting
filename = *.py

# Show source code for each error
show-source = true

# Show pep8 error codes for each error
show-pep8 = true

# Count errors and warnings
count = true

# Enable additional error checks
select = E,W,F,C

# Per-file ignores (if needed)
per-file-ignores =
    # Allow unused imports in __init__.py files
    __init__.py:F401
    # Allow longer lines in test files for readability
    tests/*.py:E501
