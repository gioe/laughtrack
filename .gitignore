# Node / Next.js
apps/web/node_modules/
apps/web/.next/
apps/web/out/
apps/web/.vercel/
apps/web/*.tsbuildinfo
apps/web/next-env.d.ts
apps/web/.env*.local
apps/web/coverage/

# Python / Scraper
apps/scraper/.venv/
apps/scraper/__pycache__/
apps/scraper/*.py[cod]
apps/scraper/.pytest_cache/
apps/scraper/.mypy_cache/
apps/scraper/.ruff_cache/
apps/scraper/.import_linter_cache/
apps/scraper/data/processed/
apps/scraper/logs/
apps/scraper/metrics/
apps/scraper/dashboard.html
apps/scraper/.env

# Repo-root logs — logs/main/app.log itself is tracked, but rotated
# files (logs/main/app.log.YYYY-MM-DD) are runtime artifacts.
logs/main/*.log.*

# Shared
.DS_Store
*.pem
.venv/

# Stray root node_modules — there is no root package.json; this only
# appears when a tool is accidentally run from the repo root.
/node_modules/

# tusk install files
.claude/bin/
.claude/settings.json
.claude/tusk-manifest.json
.claude/scheduled_tasks.lock
.mcp.json

# tusk database
tusk/tasks.db
tusk/tasks.db-shm
tusk/tasks.db-wal

# tusk generated files
tusk/laughtrack-dashboard.html
.env*.local
.vercel

# iOS / Xcode (generated)
ios/.build/
ios/DerivedData/
ios/build/
ios/**/xcuserdata/
tusk/backups/

# Fastlane (generated artifacts + bundler vendor dir)
# Note: ios/fastlane/screenshots/ is intentionally NOT ignored — that's the
# committed source of truth for App Store screenshots, read by `deliver`.
ios/fastlane/report.xml
ios/fastlane/Preview.html
ios/fastlane/README.md
ios/fastlane/test_output/
ios/vendor/bundle/
ios/.bundle/

# superpowers runtime artifacts (pid files, brainstorm HTML, server state)
.superpowers/

# Git worktrees
.worktrees/

# Playwright MCP scratch output (timestamped page/console dumps)
.playwright-mcp/
