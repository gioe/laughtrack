# Required: 6.9" iPhone covers all mandatory App Store iPhone sizes.
# App Store Connect auto-scales for smaller devices.
# When iPad support is enabled, add "iPad Pro 13-inch (M4)".
devices([
  "iPhone 16 Pro Max"
])

languages(["en-US"])

ios_version("18.3")

scheme("LaughTrack")

output_directory("./fastlane/screenshots")

clear_previous_screenshots(true)

override_status_bar(true)

# Tier 2 work will create this UI test target. Until then this lane will fail
# at the xcodebuild step with "no matching test cases."
only_testing(["LaughTrackUITests/AppStoreScreenshotTests/testGenerateAllScreenshots"])

launch_arguments(["-UITestMockMode"])

stop_after_first_error(true)

# Don't erase — avoids full SPM re-resolution
erase_simulator(false)

# Run devices sequentially to avoid resource contention
concurrent_simulators(false)

# Increase number of retries
number_of_retries(1)
