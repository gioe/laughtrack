default_platform(:ios)

APPLE_KEY_ID = "UCV7S354H2"
APPLE_ISSUER_ID = "69a6de89-0f14-47e3-e053-5b8c7c11a4d1"
APPLE_KEY_PATH = File.expand_path("~/Desktop/keys/AuthKey_UCV7S354H2.p8")

APP_IDENTIFIER = "app.laughtrack.ios"
SCHEME = "LaughTrack"
INFO_PLIST_PATH = "Sources/LaughTrackApp/Info.plist"
PROJECT_YML_PATH = "../project.yml"
IPA_NAME = "LaughTrack.ipa"
TEAM_ID = "4HDNC3V5Q6"

# Read a project.yml build setting (e.g. "CURRENT_PROJECT_VERSION") by regex.
# project.yml is the source of truth for build/marketing version (TASK-1902) —
# Info.plist embeds $(CURRENT_PROJECT_VERSION) / $(MARKETING_VERSION) and Xcode
# substitutes at build time, so reading the plist returns the unresolved literal.
#
# Scans every occurrence of the key and asserts all targets carry the same value.
# Falling back to the first match would silently grab a framework target's value
# (LaughTrackCore appears before LaughTrack in project.yml) if the values ever
# drifted; raising loudly forces a deliberate fix instead of guessing.
def read_project_yml_setting(key)
  contents = File.read(PROJECT_YML_PATH)
  values = contents.scan(/#{Regexp.escape(key)}:\s*"([^"]*)"/).flatten
  raise "#{key} not found in #{PROJECT_YML_PATH}" if values.empty?
  unique = values.uniq
  if unique.length > 1
    raise "#{key} has divergent values across targets in #{PROJECT_YML_PATH}: #{unique.inspect}. " \
          "Reconcile manually before bumping."
  end
  unique.first
end

# Replace every quoted occurrence of `key: "..."` in project.yml. CURRENT_PROJECT_VERSION
# appears once (LaughTrack target only). MARKETING_VERSION appears on every target —
# they share the same marketing version by design, so replacing all is correct.
def update_project_yml_setting(key, new_value)
  contents = File.read(PROJECT_YML_PATH)
  updated = contents.gsub(/(#{Regexp.escape(key)}:\s*)"[^"]*"/, "\\1\"#{new_value}\"")
  raise "#{key} not found in #{PROJECT_YML_PATH}" if updated == contents
  File.write(PROJECT_YML_PATH, updated)
end

platform :ios do
  before_all do
    setup_ci if ENV["CI"]
  end

  desc "Load App Store Connect API key"
  lane :load_asc_api_key do
    app_store_connect_api_key(
      key_id: APPLE_KEY_ID,
      issuer_id: APPLE_ISSUER_ID,
      key_filepath: APPLE_KEY_PATH,
      duration: 1200,
      in_house: false
    )
  end

  desc "Create or fetch Apple Distribution certificate"
  lane :create_certificate do
    load_asc_api_key

    get_certificates(generate_apple_certs: true)
  end

  desc "Fetch or create App Store provisioning profile"
  lane :sync_profiles do
    load_asc_api_key

    get_provisioning_profile(
      app_identifier: APP_IDENTIFIER
    )
  end

  desc "Increment build number (latest from ASC) and bump the marketing version's last segment"
  lane :bump_build_number do
    load_asc_api_key

    current_build = latest_testflight_build_number(
      app_identifier: APP_IDENTIFIER,
      initial_build_number: 0
    )
    new_build = current_build + 1

    current_version = read_project_yml_setting("MARKETING_VERSION")
    version_parts = current_version.to_s.split(".")
    version_parts[-1] = (version_parts[-1].to_i + 1).to_s
    new_version = version_parts.join(".")

    update_project_yml_setting("CURRENT_PROJECT_VERSION", new_build.to_s)
    update_project_yml_setting("MARKETING_VERSION", new_version)

    # Regenerate LaughTrack.xcodeproj so the new build settings land in pbxproj. Info.plist
    # embeds $(CURRENT_PROJECT_VERSION) / $(MARKETING_VERSION) and is unaffected.
    Dir.chdir("..") do
      sh("xcodegen", "generate")
    end

    # Commit + push the bump so tag_release tags a HEAD that is reachable on origin.
    # Without this, the working tree is dirty after release/beta runs end-to-end and
    # tag_release adds the tag against the unbumped HEAD commit — git checkout v1.1-N
    # would land on a commit whose project.yml + pbxproj still carry the old build
    # number. Pushing the commit first is required for the subsequent tag_release
    # step: push_git_tags refuses tags pointing at commits not reachable on the
    # remote. tags: false keeps this push commits-only — tag_release pushes its own
    # tag separately. The CI guard added in TASK-1902 (CURRENT_PROJECT_VERSION must
    # not decrease vs origin/main) makes this drift between "bumped on disk" and
    # "committed in git" especially dangerous, since the next operator can land a
    # PR that silently regresses the build number.
    git_commit(
      path: ["../project.yml", "../LaughTrack.xcodeproj/project.pbxproj"],
      message: "[fastlane] Bump build to #{new_build}"
    )
    # Omit local_branch so fastlane resolves the actual current branch via
    # Actions.git_branch_name_using_HEAD; passing "HEAD" would assemble
    # `git push origin HEAD:HEAD`, which the remote refuses (refusing to
    # update checked out branch). tags: false keeps this push commits-only —
    # tag_release pushes its own tag separately.
    push_to_git_remote(
      remote: "origin",
      tags: false
    )

    UI.success("Bumped version #{current_version} → #{new_version}, build → #{new_build}")
  end

  desc "Build the app for App Store distribution"
  lane :build do |options|
    load_asc_api_key

    get_provisioning_profile(
      app_identifier: APP_IDENTIFIER
    )

    profile_name = lane_context[SharedValues::SIGH_NAME]

    build_app(
      scheme: SCHEME,
      output_directory: "./build",
      output_name: IPA_NAME,
      export_method: "app-store",
      clean: true,
      export_options: {
        signingStyle: "manual",
        teamID: TEAM_ID,
        provisioningProfiles: {
          APP_IDENTIFIER => profile_name
        }
      }
    )
  end

  desc "Upload to TestFlight"
  lane :upload_testflight do
    load_asc_api_key

    upload_to_testflight(
      ipa: "./build/#{IPA_NAME}",
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end

  desc "Capture App Store screenshots on all devices"
  lane :screenshots do
    capture_screenshots
  end

  desc "Add device frames and captions to screenshots"
  lane :frames do
    frame_screenshots(
      path: "./fastlane/screenshots",
      force_device_type: "iPhone 16 Pro Max"
    )
  end

  desc "Capture screenshots, frame them, then upload"
  lane :screenshots_and_upload do
    screenshots
    frames
    upload_metadata
  end

  desc "Upload metadata and screenshots to App Store Connect"
  lane :upload_metadata do
    load_asc_api_key

    deliver(
      submit_for_review: false,
      automatic_release: false,
      force: true,
      skip_metadata: false,
      skip_screenshots: false,
      skip_binary_upload: true,
      overwrite_screenshots: true,
      precheck_include_in_app_purchases: false,
      app_review_information: {
        demo_account_required: false
      }
    )
  end

  desc "Upload IPA + metadata + screenshots to ASC in one deliver call (creates the version record)"
  lane :upload_app_store do
    load_asc_api_key

    deliver(
      ipa: "./build/#{IPA_NAME}",
      submit_for_review: false,
      automatic_release: false,
      force: true,
      skip_metadata: false,
      skip_screenshots: false,
      skip_binary_upload: false,
      precheck_include_in_app_purchases: false,
      app_review_information: {
        demo_account_required: false
      }
    )
  end

  desc "Submit for App Store review (includes metadata + screenshots)"
  lane :submit_review do
    load_asc_api_key

    deliver(
      submit_for_review: true,
      automatic_release: false,
      force: true,
      skip_metadata: false,
      skip_screenshots: false,
      submission_information: {
        add_id_info_uses_idfa: false
      },
      precheck_include_in_app_purchases: false,
      app_review_information: {
        demo_account_required: false
      }
    )
  end

  desc "Full pipeline: release notes, screenshots, bump build, build, upload, and submit for review"
  lane :release do
    generate_release_notes
    screenshots
    frames
    bump_build_number
    build
    upload_testflight
    submit_review
    tag_release
  end

  desc "Build and upload to App Store Connect (creates version, uploads metadata + screenshots, pushes to TestFlight)"
  lane :beta do
    generate_release_notes
    bump_build_number
    build
    upload_app_store
    tag_release
  end

  desc "Tag the current commit with v{version}-{build}"
  lane :tag_release do
    version = read_project_yml_setting("MARKETING_VERSION")
    build_num = read_project_yml_setting("CURRENT_PROJECT_VERSION")
    tag = "v#{version}-#{build_num}"

    if git_tag_exists(tag: tag)
      UI.important("Tag #{tag} already exists, skipping")
    else
      add_git_tag(tag: tag)
      push_git_tags(tag: tag)
      UI.success("Tagged #{tag}")
    end
  end

  desc "Generate release notes from commits since the last tag"
  lane :generate_release_notes do
    tag = last_git_tag

    if tag.nil? || tag.empty?
      UI.important("No previous tag found — using last 50 commits that touched ios/")
      raw = changelog_from_git_commits(commits_count: 50, pretty: "%s", app_path: ".")
    else
      raw = changelog_from_git_commits(between: [tag, "HEAD"], pretty: "%s", app_path: ".")
    end

    lines = raw.split("\n").map(&:strip).reject(&:empty?)

    entries = lines.reject { |line| line.match?(/^Merge |^Co-Authored-By:/i) }

    features = []
    fixes = []
    improvements = []

    entries.each do |summary|
      lower = summary.downcase
      if lower.match?(/\bfix(es|ed)?\b|\bbug\b|\bcrash\b|\bresolve[sd]?\b|\bpatch\b/)
        fixes << summary
      elsif lower.match?(/\badd(s|ed)?\b|\bnew\b|\bcreate[sd]?\b|\bintroduce[sd]?\b|\bimplement[sed]?\b|\bfeature\b/)
        features << summary
      else
        improvements << summary
      end
    end

    sections = []
    sections << "New Features\n#{features.map { |f| "• #{f}" }.join("\n")}" unless features.empty?
    sections << "Bug Fixes\n#{fixes.map { |f| "• #{f}" }.join("\n")}" unless fixes.empty?
    sections << "Improvements\n#{improvements.map { |f| "• #{f}" }.join("\n")}" unless improvements.empty?

    notes_text = sections.empty? ? "• Bug fixes and performance improvements" : sections.join("\n\n")

    max_len = 4000
    if notes_text.length > max_len
      truncated = notes_text[0...max_len]
      last_newline = truncated.rindex("\n")
      notes_text = last_newline ? truncated[0...last_newline] : truncated
    end

    release_notes_path = File.join(Dir.pwd, "metadata", "en-US", "release_notes.txt")
    FileUtils.mkdir_p(File.dirname(release_notes_path))
    File.write(release_notes_path, notes_text)
    UI.success("Wrote release_notes.txt (#{notes_text.length} chars)")

    notes_text
  end
end
